{
  "name": "@hasagi/ingame-api",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "build": "node scripts/prebuild.mjs && tsc && node scripts/postbuild.mjs",
    "check:package": "npm run build && publint ./dist && attw --pack ./dist",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "release": "npm run check:package && cd ./dist && npm publish --access public"
  },
  "keywords": [
    "hasagi"
  ],
  "author": "dysolix",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.18.0",
    "tiny-typed-emitter": "^2.1.0"
  },
  "type": "commonjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    }
  },
  "main": "./index.js",
  "types": "./index.d.ts",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^20.19.42",
    "eslint": "^10.5.0",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
